prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["npm", "run", "build"], decision="allow")
prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "ELECTRON_ENABLE_LOGGING=1 ./node_modules/.bin/electron ."], decision="allow")
prefix_rule(pattern=["git", "checkout", "-b"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m"], decision="allow")
prefix_rule(pattern=["git", "remote", "show"], decision="allow")
prefix_rule(pattern=["git", "push", "-u", "origin"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "--heads", "origin"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "empty_tree=$(printf '' | git hash-object -t tree --stdin) && base_commit=$(printf 'chore: initialize repository\\n' | git commit-tree \"$empty_tree\") && git branch main \"$base_commit\" && printf '%s' \"$base_commit\""], decision="allow")
prefix_rule(pattern=["git", "cherry-pick"], decision="allow")
prefix_rule(pattern=["pnpm", "install"], decision="allow")
prefix_rule(pattern=["pnpm", "rebuild"], decision="allow")
prefix_rule(pattern=["pnpm", "run", "build"], decision="allow")
prefix_rule(pattern=["pnpm", "exec", "playwright", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "run", "test:e2e"], decision="allow")
prefix_rule(pattern=["git", "push"], decision="allow")
prefix_rule(pattern=["gh", "pr", "edit"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "CI=true pnpm install --no-frozen-lockfile"], decision="allow")
prefix_rule(pattern=["pip3", "install", "-e"], decision="allow")
prefix_rule(pattern=["pip3", "install"], decision="allow")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
prefix_rule(pattern=["pnpm", "exec", "lefthook", "install"], decision="allow")
prefix_rule(pattern=["node", "./scripts/format-staged-files.mjs"], decision="allow")
prefix_rule(pattern=["pnpm", "build"], decision="allow")
prefix_rule(pattern=["pip3.11", "install"], decision="allow")
prefix_rule(pattern=["git", "apply", "--cached"], decision="allow")
prefix_rule(pattern=["git", "reset", "HEAD", "IMPLEMENTATION_PLAN.md"], decision="allow")
prefix_rule(pattern=["git", "commit", "--no-verify", "-m"], decision="allow")
prefix_rule(pattern=["git", "restore"], decision="allow")
prefix_rule(pattern=["git", "mv"], decision="allow")
